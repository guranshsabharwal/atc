{
  "name": "atc-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @atc/database db:generate",
    "db:push": "pnpm --filter @atc/database db:push",
    "db:studio": "pnpm --filter @atc/database db:studio",
    "typecheck": "turbo run typecheck",
    "test:e2e": "turbo run test:e2e"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}